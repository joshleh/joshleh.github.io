---
const links = [
  { label: 'GitHub', href: 'https://github.com/joshleh' },
  { label: 'LinkedIn', href: 'https://linkedin.com/in/joshleh/' },
  { label: 'Email', href: 'mailto:joshdmleh@gmail.com' },
];
---

<section class="max-w-2xl mx-auto px-6 pt-32 pb-8">
  <div class="flex flex-col sm:flex-row sm:items-center gap-6 mb-6">
    <img
      src="/profile.png"
      alt="Joshua Lee"
      width="96"
      height="96"
      class="w-24 h-24 rounded-full object-cover ring-2 ring-border"
    />
    <div>
      <h1 class="text-5xl sm:text-6xl font-bold text-white tracking-tight">
        Joshua Lee
      </h1>
      <p class="mt-3 text-lg text-muted leading-relaxed max-w-lg">
        Machine Learning Engineer & Racket Sports Enthusiast
      </p>
    </div>
  </div>
  <nav class="mt-8 flex flex-wrap gap-5">
    {links.map(link => (
      <a
        href={link.href}
        target={link.href.startsWith('/') ? undefined : '_blank'}
        rel={link.href.startsWith('/') ? undefined : 'noopener noreferrer'}
        class="text-sm text-accent hover:text-white transition-colors"
      >
        {link.label}&nbsp;&rarr;
      </a>
    ))}
  </nav>
</section>
