---
interface Degree {
  school: string;
  degree: string;
  period: string;
}

const education: Degree[] = [
  {
    school: 'University of Southern California',
    degree: 'Master of Science, Applied Data Science',
    period: 'May 2026 – Dec 2027',
  },
  {
    school: 'University of California, San Diego',
    degree: 'Bachelor of Science, Data Science',
    period: 'Sep 2022 – Mar 2026',
  },
];
---

<section id="education" class="max-w-2xl mx-auto px-6 py-16">
  <h2 class="text-sm font-medium uppercase tracking-widest text-muted mb-10">
    Education
  </h2>
  <div class="flex flex-col gap-8">
    {education.map(edu => (
      <div class="border-l-2 border-accent-dim pl-4 flex flex-col sm:flex-row sm:items-baseline sm:justify-between gap-1">
        <div>
          <h3 class="text-base font-semibold text-white">{edu.school}</h3>
          <p class="text-sm text-gray-400">{edu.degree}</p>
        </div>
        <span class="text-xs text-muted shrink-0">{edu.period}</span>
      </div>
    ))}
  </div>
</section>
